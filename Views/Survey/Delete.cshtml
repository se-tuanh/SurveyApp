@model SurveyApp.Models.Survey
@{
    ViewData["Title"] = "Xóa khảo sát";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-body p-4 text-center">
                <i class="bi bi-exclamation-triangle display-3 text-danger mb-3"></i>
                <h4 class="fw-bold">Xác nhận xóa</h4>
                <p class="text-muted">Bạn có chắc chắn muốn xóa khảo sát <strong>"@Model.Title"</strong>?<br />
                Toàn bộ câu hỏi và kết quả trả lời sẽ bị xóa vĩnh viễn.</p>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex gap-2 justify-content-center mt-3">
                    <button type="submit" class="btn btn-danger fw-semibold">
                        <i class="bi bi-trash me-1"></i>Xóa khảo sát
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                </form>
            </div>
        </div>
    </div>
</div>
