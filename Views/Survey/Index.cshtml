@model IEnumerable<SurveyApp.Models.Survey>
@{
    ViewData["Title"] = "Khảo sát của tôi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-list-ul text-primary me-2"></i>Khảo sát của tôi</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Tạo mới
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-clipboard display-1 text-muted"></i>
        <p class="mt-3 text-muted">Bạn chưa có khảo sát nào.</p>
        <a asp-action="Create" class="btn btn-primary">Tạo khảo sát đầu tiên</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-primary">
                <tr>
                    <th>Tiêu đề</th>
                    <th>Số câu hỏi</th>
                    <th>Lượt trả lời</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var survey in Model)
                {
                    <tr>
                        <td class="fw-semibold">@survey.Title</td>
                        <td><span class="badge bg-info">@survey.Questions.Count câu</span></td>
                        <td><span class="badge bg-secondary">@survey.Responses.Count lượt</span></td>
                        <td>
                            @if (survey.IsActive)
                            {
                                <span class="badge bg-success">Đang mở</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã đóng</span>
                            }
                        </td>
                        <td class="text-muted small">@survey.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@survey.Id" class="btn btn-outline-primary" title="Chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@survey.Id" class="btn btn-outline-warning" title="Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-controller="Statistics" asp-action="Index" asp-route-surveyId="@survey.Id"
                                   class="btn btn-outline-success" title="Thống kê">
                                    <i class="bi bi-bar-chart"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@survey.Id" class="btn btn-outline-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
