@model IEnumerable<SurveyApp.Models.Survey>
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="row mb-4">
    <div class="col">
        <h2 class="fw-bold"><i class="bi bi-clipboard-data me-2 text-primary"></i>Khảo sát đang mở</h2>
        <p class="text-muted">Tham gia các khảo sát đang diễn ra dưới đây.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <p class="mt-3 text-muted">Chưa có khảo sát nào đang mở.</p>
        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Survey" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Tạo khảo sát mới
            </a>
        }
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var survey in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@survey.Title</h5>
                        <p class="card-text text-muted small">@(survey.Description ?? "Không có mô tả")</p>
                        <div class="d-flex gap-3 text-muted small mb-3">
                            <span><i class="bi bi-question-circle me-1"></i>@survey.Questions.Count câu hỏi</span>
                            <span><i class="bi bi-people me-1"></i>@survey.Responses.Count lượt trả lời</span>
                        </div>
                        <p class="text-muted small"><i class="bi bi-person me-1"></i>@(survey.CreatedBy?.FullName ?? survey.CreatedBy?.Email)</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <a asp-controller="Response" asp-action="Take" asp-route-surveyId="@survey.Id"
                               class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-pencil-square me-1"></i>Tham gia khảo sát
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập để tham gia
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
