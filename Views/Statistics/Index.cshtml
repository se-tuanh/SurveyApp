@model SurveyApp.Models.Survey
@{
    ViewData["Title"] = "Thống kê khảo sát";
    int totalResponses = Model.Responses.Count;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-bar-chart text-success me-2"></i>@Model.Title</h2>
        <p class="text-muted mb-0">Tổng số lượt trả lời: <strong class="text-primary">@totalResponses</strong></p>
    </div>
    <a asp-controller="Survey" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

@if (totalResponses == 0)
{
    <div class="text-center py-5 bg-light rounded">
        <i class="bi bi-inbox display-3 text-muted"></i>
        <p class="mt-3 text-muted">Chưa có ai trả lời khảo sát này.</p>
    </div>
}
else
{
    @for (int i = 0; i < Model.Questions.Count; i++)
    {
        var question = Model.Questions.ElementAt(i);
        <div class="card mb-4 shadow-sm border-0">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3">
                    <span class="badge bg-primary me-2">@(i + 1)</span>@question.Text
                    <span class="badge @(question.QuestionType == SurveyApp.Models.QuestionType.MultipleChoice ? "bg-info" : "bg-secondary") ms-2 small">
                        @(question.QuestionType == SurveyApp.Models.QuestionType.MultipleChoice ? "Trắc nghiệm" : "Tự luận")
                    </span>
                </h6>

                @if (question.QuestionType == SurveyApp.Models.QuestionType.MultipleChoice)
                {
                    var allAnswers = Model.Responses.SelectMany(r => r.Answers)
                        .Where(a => a.QuestionId == question.Id).ToList();
                    int answered = allAnswers.Count(a => a.SelectedOptionId.HasValue);

                    @foreach (var option in question.Options)
                    {
                        int count = allAnswers.Count(a => a.SelectedOptionId == option.Id);
                        double pct = answered > 0 ? Math.Round((double)count / answered * 100, 1) : 0;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>@option.Text</span>
                                <span class="text-muted small">@count / @answered (@pct%)</span>
                            </div>
                            <div class="progress" style="height: 22px;">
                                <div class="progress-bar bg-primary" style="width: @pct%">@pct%</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    var textAnswers = Model.Responses.SelectMany(r => r.Answers)
                        .Where(a => a.QuestionId == question.Id && !string.IsNullOrWhiteSpace(a.TextAnswer))
                        .ToList();
                    <p class="text-muted small mb-2">@textAnswers.Count câu trả lời</p>
                    <ul class="list-group list-group-flush">
                        @foreach (var ans in textAnswers)
                        {
                            <li class="list-group-item px-0 py-2 border-0 border-bottom">
                                <i class="bi bi-chat-text text-muted me-2"></i>@ans.TextAnswer
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
}
