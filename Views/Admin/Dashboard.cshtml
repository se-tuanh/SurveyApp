@model SurveyApp.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Admin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-speedometer2 text-primary me-2"></i>Dashboard</h2>
    <a asp-action="Users" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-people me-1"></i>Quản lý người dùng
    </a>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0d6efd !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-clipboard-data text-primary fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-primary">@Model.TotalSurveys</div>
                    <div class="text-muted small">Tổng khảo sát</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #198754 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-check-circle text-success fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-success">@Model.ActiveSurveys</div>
                    <div class="text-muted small">Đang hoạt động</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #ffc107 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-pencil-square text-warning fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-warning">@Model.TotalResponses</div>
                    <div class="text-muted small">Lượt trả lời</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0dcaf0 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="bi bi-people text-info fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-info">@Model.TotalUsers</div>
                    <div class="text-muted small">Người dùng</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Top Surveys -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 fw-bold pt-3">
                <i class="bi bi-trophy text-warning me-2"></i>Top khảo sát theo lượt trả lời
            </div>
            <div class="card-body p-0">
                @if (!Model.TopSurveys.Any())
                {
                    <p class="text-muted text-center py-4">Chưa có dữ liệu</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Tiêu đề</th>
                                    <th class="text-center">Câu hỏi</th>
                                    <th class="text-center">Trả lời</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.TopSurveys)
                                {
                                    <tr>
                                        <td class="fw-semibold">@s.Title</td>
                                        <td class="text-center"><span class="badge bg-info">@s.QuestionCount</span></td>
                                        <td class="text-center"><span class="badge bg-primary">@s.ResponseCount</span></td>
                                        <td class="text-center">
                                            <span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">
                                                @(s.IsActive ? "Mở" : "Đóng")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <a asp-controller="Statistics" asp-action="Index" asp-route-surveyId="@s.SurveyId"
                                                   class="btn btn-outline-success btn-sm" title="Thống kê">
                                                    <i class="bi bi-bar-chart"></i>
                                                </a>
                                                <a asp-action="ExportExcel" asp-route-surveyId="@s.SurveyId"
                                                   class="btn btn-outline-success btn-sm" title="Xuất Excel">
                                                    <i class="bi bi-file-earmark-excel"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Responses -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 fw-bold pt-3">
                <i class="bi bi-clock-history text-primary me-2"></i>Hoạt động gần đây
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentResponses.Any())
                {
                    <p class="text-muted text-center py-4">Chưa có hoạt động</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var r in Model.RecentResponses)
                        {
                            <li class="list-group-item px-3 py-2">
                                <div class="d-flex align-items-start gap-2">
                                    <i class="bi bi-person-circle text-muted mt-1"></i>
                                    <div>
                                        <div class="small fw-semibold">@r.UserName</div>
                                        <div class="text-muted small">đã trả lời <em>@r.SurveyTitle</em></div>
                                        <div class="text-muted" style="font-size:0.75rem">
                                            @r.SubmittedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
